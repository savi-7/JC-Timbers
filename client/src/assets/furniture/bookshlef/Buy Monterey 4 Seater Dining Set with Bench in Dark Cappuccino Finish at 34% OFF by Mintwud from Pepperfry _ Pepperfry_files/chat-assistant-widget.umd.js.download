                  max-height: 100vh !important;
                  max-height: calc(var(--vh, 1vh) * 100) !important;
                  border-radius: 0 !important;
                  bottom: 0 !important;
                  right: 0 !important;
                }
                #messages-container {
                  height: calc(100vh - 130px) !important;
                  height: calc(calc(var(--vh, 1vh) * 100) - 130px) !important;
