          @media (max-width: 768px) {
            .chat-window {
              width: 100% !important;
              height: 100vh !important;
              height: calc(var(--vh, 1vh) * 100) !important;
              margin: 0 !important;
              max-height: 100vh !important;
              max-height: calc(var(--vh, 1vh) * 100) !important;
              border-radius: 0 !important;
            }
            .messages-area {
              height: calc(100vh - 130px) !important;
              height: calc(calc(var(--vh, 1vh) * 100) - 130px) !important;
            }
          }
          @keyframes expandChat {
            0% {
              transform: scale(0);
              transform-origin: bottom right;
              opacity: 0;
            }
            100% {
              transform: scale(1);
              transform-origin: bottom right;
              opacity: 1;
            }
          }
          @keyframes minimizeChat {
            0% {
              transform: scale(1);
              transform-origin: bottom right;
              opacity: 1;
            }
            100% {
              transform: scale(0);
              transform-origin: bottom right;
              opacity: 1;
            }
          }
          
          @keyframes queueDots {
            0% {
              opacity: 0.3;
              transform: scale(1);
            }
            50% {
              opacity: 1;
              transform: scale(1.2);
            }
            100% {
              opacity: 0.3;
              transform: scale(1);
            }
          }
          
          @keyframes queuePulse {
            0% {
              box-shadow: 0 4px 12px rgba(255, 215, 0, 0.15);
            }
            50% {
              box-shadow: 0 6px 20px rgba(255, 215, 0, 0.25);
            }
            100% {
              box-shadow: 0 4px 12px rgba(255, 215, 0, 0.15);
            }
          }
          
          @keyframes queueEntrance {
            0% {
              opacity: 0;
              transform: translateY(20px) scale(0.9);
            }
            100% {
              opacity: 1;
              transform: translateY(0) scale(1);
            }
          }
          
          .queue-notification:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 215, 0, 0.3) !important;
          }
          .hide-scrollbar {
            -ms-overflow-style: none !important;
            scrollbar-width: none !important;
          }
          .hide-scrollbar::-webkit-scrollbar {
            display: none !important;
          }
          
          /* PDF Viewer Styles */
          .pdf-viewer-container {
            pointer-events: auto !important;
            user-select: auto !important;
          }
          
          .pdf-viewer-container * {
            pointer-events: auto !important;
            user-select: auto !important;
          }
          
          /* Ensure chat is not interactive when PDF is open */
          .chat-window.pdf-open {
            pointer-events: none !important;
            user-select: none !important;
          }
          
          .chat-window.pdf-open * {
            pointer-events: none !important;
            user-select: none !important;
          }
        `}),!x&&jsxRuntimeExports.jsx("div",{style:{position:"fixed",bottom:"16px",right:"16px",zIndex:1002,pointerEvents:"auto"},children:jsxRuntimeExports.jsx("div",{onClick:Uo,onMouseEnter:ii,onMouseLeave:Qo,style:{width:"280px",height:"60px",backgroundColor:"transparent",position:"absolute",bottom:"110px",right:"0",cursor:"pointer"}})}),a&&x&&!Mt?jsxRuntimeExports.jsxs(jsxRuntimeExports.Fragment,{children:[jsxRuntimeExports.jsx("style",{children:`
